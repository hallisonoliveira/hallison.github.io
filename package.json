{
  "name": "hallison-blog",
  "version": "1.0.0",
  "description": "Personal blog with i18n support",
  "scripts": {
    "validate:i18n": "node scripts/validate-i18n-keys.js",
    "validate:content": "node scripts/validate-i18n.js",
    "test:content": "node tests/validate-i18n.test.js",
    "test:build": "bash scripts/validate-build.sh",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "hugo:server": "wsl /snap/bin/hugo server --port 1313 --bind 0.0.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "js-yaml": "^4.1.1"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
